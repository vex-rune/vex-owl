# ================================================
# Vex-Owl 项目通用 .gitignore
# ================================================

# ================================================
# Java / Maven 后端构建产物
# ================================================
**/target/**
*.jar
*.war
*.ear
*.class
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar

# ================================================
# Flutter / Dart 前端构建产物
# ================================================
**/owl-client/**/GeneratedPluginRegistrant.*
**/owl-client/**/Generated*.xcconfig
**/owl-client/.dart_tool/
**/owl-client/.packages
**/owl-client/.flutter-plugins
**/owl-client/.flutter-plugins-dependencies
**/owl-client/.fvm/
**/owl-client/build/
**/owl-client/pubspec.lock
**/owl-client/*.lock
.pub-cache/
.pub/

# ================================================
# Vite / React 前端构建产物
# ================================================
**/owl-admin/node_modules/
**/owl-admin/dist/
**/owl-admin/.vite/
**/owl-admin/coverage/
**/owl-admin/.eslintcache
**/owl-admin/*.local

# Dart code generation
*.g.dart
*.freezed.dart
*.mocks.dart

# Melos
/melos.yaml
/melos_project.yaml
/.melos.json

# ================================================
# IDE 配置
# ================================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.iml
*.ipr
*.iws
.DS_Store

# ================================================
# 操作系统缓存
# ================================================
Thumbs.db
Desktop.ini
*.tmp
*.bak
*.cache

# ================================================
# 日志文件
# ================================================
*.log
logs/
*.log.*
*.gz

# ================================================
# Python（如果有Python脚本）
# ================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
*.egg-info/
.installed.cfg
*.egg

# ================================================
# 本地数据和工作空间（不提交到 git）
# ================================================
/data/**
/server/data/**
/server/config-data/**
owl-workspace/users/*
!owl-workspace/users/.gitkeep

# Nacos 配置本地缓存
server/data/nacos/
server/config-data/
docker/vex-group/data/**
owl-docker-container/data/**

