# ================================================
# Vex-Owl 项目通用 .gitignore
# ================================================

/data

# ================================================
# Java / Maven 后端构建产物
# ================================================
**/target/**
*.jar
*.war
*.ear
*.class
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar

# ================================================
# Flutter / Dart 前端构建产物
# ================================================
# ==============================================
# 1. 通用杂项文件
# ==============================================
*.class
*.log
*.pyc
*.swp
*.lock
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/
*.tmp
*.bak

# ==============================================
# 2. Dart & Flutter 核心文件
# ==============================================
# Dart工具目录（自动生成）
.dart_tool/
# 包引用文件（自动生成）
.packages
# 插件注册表（自动生成）
.flutter-plugins
.flutter-plugins-dependencies
# 构建输出目录（所有平台的编译产物）
/build/
# 文档生成目录
**/doc/api/
# 生成的插件注册文件
**/generated_plugin_registrant.dart
# Flutter编译临时文件
flutter_*.png
linked_*.ds
unlinked.ds
unlinked_spec.ds
# Pub缓存（本地依赖缓存）
.pub-cache/
.pub/

# ==============================================
# 3. Android 平台
# ==============================================
**/android/**/gradle-wrapper.jar
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/local.properties  # 本地SDK路径配置
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties    # 签名密钥配置（敏感！绝对不能提交）
*.jks                         # 签名密钥文件（敏感！绝对不能提交）
*.keystore

# Flutter作为Module集成时的.android目录
**/.android/**/gradle-wrapper.jar
**/.android/.gradle/
**/.android/captures/
**/.android/gradlew
**/.android/gradlew.bat
**/.android/local.properties
**/.android/**/GeneratedPluginRegistrant.java
**/.android/key.properties

