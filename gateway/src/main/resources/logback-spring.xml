<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 引入Spring Boot默认配置 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 控制台输出 - 彩色日志格式 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n%wEx</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 文件输出 - 详细格式 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/gateway.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>logs/gateway.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 过滤器专用日志格式 - 更美观的输出 -->
    <appender name="FILTER_LOG" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{HH:mm:ss.SSS}){faint} %clr(%5p) %clr([%t]){faint} %clr(%logger{20}){cyan} %clr(:){faint} %m%n%wEx</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 根日志级别 - 由profile控制 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <!-- Spring Framework 日志 -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.cloud.gateway" level="INFO"/>
    
    <!-- 网关过滤器日志 -->
    <logger name="com.vex.owl.gateway.filter" level="INFO" additivity="false">
        <appender-ref ref="FILTER_LOG"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- JWT 相关日志 -->
    <logger name="io.jsonwebtoken" level="WARN"/>
    
    <!-- Nacos 日志 -->
    <logger name="com.alibaba.nacos" level="INFO"/>
    
    <!-- Reactor 日志 -->
    <logger name="reactor.netty" level="WARN"/>
    
    <!-- Hibernate/Database 日志（如果有） -->
    <logger name="org.hibernate" level="WARN"/>

    <!-- 本地开发环境配置 -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
        
        <logger name="com.vex.owl.gateway.filter" level="DEBUG" additivity="false">
            <appender-ref ref="FILTER_LOG"/>
        </logger>
        
        <logger name="org.springframework.cloud.gateway" level="DEBUG"/>
        <logger name="org.springframework.web" level="DEBUG"/>
    </springProfile>

    <!-- 生产环境配置 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
        
        <logger name="com.vex.owl.gateway.filter" level="INFO" additivity="false">
            <appender-ref ref="FILTER_LOG"/>
            <appender-ref ref="FILE"/>
        </logger>
        
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.springframework.cloud.gateway" level="WARN"/>
    </springProfile>
</configuration>
