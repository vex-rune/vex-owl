{
  "properties": [
    {
      "name": "vex.jwt.secret",
      "type": "java.lang.String",
      "description": "JWT签名密钥"
    },
    {
      "name": "vex.jwt.access-token-validity",
      "type": "java.lang.Long",
      "description": "访问令牌有效期(秒)"
    },
    {
      "name": "vex.jwt.refresh-token-validity",
      "type": "java.lang.Long",
      "description": "刷新令牌有效期(秒)"
    },
    {
      "name": "vex.jwt.issuer",
      "type": "java.lang.String",
      "description": "JWT签发者"
    },
    {
      "name": "vex.jwt.header",
      "type": "java.lang.String",
      "description": "HTTP请求头名称"
    },
    {
      "name": "vex.jwt.prefix",
      "type": "java.lang.String",
      "description": "Token前缀(如 Bearer)"
    },
    {
      "name": "vex.jwt.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用JWT功能"
    }
  ]
}